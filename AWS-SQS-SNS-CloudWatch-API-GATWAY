Create sendOrderEmail.js:


// sendOrderEmail.js
import { SNSClient, PublishCommand } from "@aws-sdk/client-sns";
import dotenv from "dotenv";
dotenv.config();

const REGION = process.env.AWS_REGION || "us-east-1";
const TOPIC_ARN = process.env.TOPIC_ARN || "arn:aws:sns:us-east-1:123456789012:order-notifications";

const sns = new SNSClient({ region: REGION });

/**
 * Publish order notification to SNS topic (which will deliver email to subscribers).
 * @param {Object} payload - plain object with order info
 */
export async function sendOrderNotification(payload) {
  const message = {
    default: `Order ${payload.orderId} placed.`,
    // email clients will see the Message (plain text). You can also customize Subject.
  };

  const params = {
    TopicArn: TOPIC_ARN,
    Message: JSON.stringify(payload), // JSON payload for subscribers that expect JSON
    Subject: `Order ${payload.orderId} — Confirmation`,
    MessageStructure: "string"
  };

  try {
    const cmd = new PublishCommand(params);
    const res = await sns.send(cmd);
    console.log("Published MessageId:", res.MessageId);
    return res;
  } catch (err) {
    console.error("Publish error:", err);
    throw err;
  }
}

// Example usage when an order is placed:
if (import.meta.url === `file://${process.argv[1]}`) {
  const exampleOrder = {
    orderId: "ORD-1001",
    customerEmail: "customer@example.com",
    items: [{ sku: "SKU-1", qty: 2 }],
    total: 129.99,
    placedAt: new Date().toISOString()
  };

  sendOrderNotification(exampleOrder).catch(() => process.exit(1));
}



What is AWS CloudWatch?

Amazon CloudWatch is a monitoring and observability service in AWS.
It helps you track, collect, and analyze metrics, logs, and events from your AWS resources and applications.


CloudWatch helps you to:

Purpose	Description
1. Monitor Metrics	:   Tracks resource usage like CPU, memory, disk, and network (for EC2, Lambda, RDS, etc.)
2. Collect Logs     :	Stores and searches application or system logs (using CloudWatch Logs)
3. Set Alarms       :	Sends alerts when a metric crosses a threshold (like high CPU usage or API errors)
4. View Dashboards  :	Create visual dashboards to track application health
5. Automate Actions :	Trigger actions (like restarting instances or sending SNS notifications) when issues occur
6. Troubleshoot     :   Performance	Helps debug latency or error issues using metrics and logs



CloudWatch in Application Level (Real-Time Use)

At the application level, CloudWatch helps you track custom business or app performance metrics — not just server metrics.
✅ Example: Node.js or .NET Application
Let’s say you have an e-commerce app running on EC2 or ECS.
You can use CloudWatch for:
Custom Metrics
Track “number of user logins,” “failed API calls,” or “payment success rate.”
You can send these metrics to CloudWatch using the AWS SDK.
// Example (Node.js)
const AWS = require('aws-sdk');
const cloudwatch = new AWS.CloudWatch();
const params = {
  MetricData: [
    {
      MetricName: 'FailedLoginAttempts',
      Dimensions: [{ Name: 'Application', Value: 'EcommerceApp' }],
      Unit: 'Count',
      Value: 5
    }
  ],
  Namespace: 'MyApp/Metrics'
};

cloudwatch.putMetricData(params, (err, data) => {
  if (err) console.log(err);
  else console.log('Metric Sent:', data);
});


Application Logs
Send your application logs to CloudWatch Logs.
Then you can search and create filters to find specific errors or patterns.

Example:

Store all your API request/response logs

Use filters to find "status":500 errors quickly.
Set Alarms

Example:
Alarm if ErrorRate > 5% for 5 minutes.
Alarm if Lambda duration > 3 seconds.
CloudWatch Dashboard
Visualize your key metrics like:
Average API latency
Error counts
Number of orders placed
Active users

