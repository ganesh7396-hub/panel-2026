import dotenv from "dotenv";
import { SQSClient, SendMessageCommand } from "@aws-sdk/client-sqs";
dotenv.config();

const REGION = process.env.AWS_REGION;
const QUEUE_URL = process.env.QUEUE_URL;

const sqs = new SQSClient({ region: REGION });

/**
 * sendOrder: sends order object to SQS
 * @param {Object} order - { orderId, customerEmail, items, total }
 */
export async function sendOrder(order) {
  const params = {
    QueueUrl: QUEUE_URL,
    // MessageBody must be a string
    MessageBody: JSON.stringify(order),
    // optional: use MessageAttributes for routing or small metadata
    MessageAttributes: {
      eventType: {
        DataType: "String",
        StringValue: "ORDER_PLACED",
      },
    },
  };

  const cmd = new SendMessageCommand(params);
  const res = await sqs.send(cmd);
  console.log("Sent messageId:", res.MessageId);
  return res;
}

