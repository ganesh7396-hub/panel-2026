// setupTopic.js
import { SNSClient, CreateTopicCommand, SubscribeCommand } from "@aws-sdk/client-sns";
import dotenv from "dotenv";
dotenv.config();

const client = new SNSClient({ region: process.env.AWS_REGION });

async function createTopicAndSubscribe(email) {
  const create = new CreateTopicCommand({ Name: "order-notifications" });
  const { TopicArn } = await client.send(create);
  console.log("TopicArn:", TopicArn);

  const subscribe = new SubscribeCommand({
    TopicArn,
    Protocol: "email",
    Endpoint: email
  });
  const res = await client.send(subscribe);
  console.log("Subscription (pending):", res.SubscriptionArn);
  return TopicArn;
}

createTopicAndSubscribe("customer@example.com")
  .catch(err => console.error("Err:", err));



