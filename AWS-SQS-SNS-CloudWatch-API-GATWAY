// consumer.js
import dotenv from "dotenv";
import { SQSClient, ReceiveMessageCommand, DeleteMessageCommand } from "@aws-sdk/client-sqs";
dotenv.config();

const REGION = process.env.AWS_REGION;
const QUEUE_URL = process.env.QUEUE_URL;

const sqs = new SQSClient({ region: REGION });

/**
 * pollAndProcess: long-polls the queue, processes messages, deletes on success
 */
async function pollAndProcess() {
  while (true) {
    try {
      const params = {
        QueueUrl: QUEUE_URL,
        MaxNumberOfMessages: 5,      // up to 10
        WaitTimeSeconds: 20,         // long polling (reduce empty responses)
        VisibilityTimeout: 30,       // seconds the message is "invisible" while processing
        MessageAttributeNames: ["All"],
      };

      const cmd = new ReceiveMessageCommand(params);
      const res = await sqs.send(cmd);

      if (!res.Messages || res.Messages.length === 0) {
        // nothing to process — loop and poll again
        continue;
      }

      for (const msg of res.Messages) {
        try {
          const body = JSON.parse(msg.Body);
          console.log("Processing order:", body.orderId);

          // --- TODO: do actual work here (send email, process payment, etc.) ---
          // simulate work with a short delay
          await new Promise((r) => setTimeout(r, 500));

          // if success -> delete message from queue
          const delCmd = new DeleteMessageCommand({
            QueueUrl: QUEUE_URL,
            ReceiptHandle: msg.ReceiptHandle,
          });
          await sqs.send(delCmd);
          console.log("Processed & deleted:", body.orderId);
        } catch (processingErr) {
          console.error("Processing error:", processingErr);
          // If we don't delete the message, it becomes visible again after visibility timeout
          // Consider sending failing messages to DLQ by configuring redrive policy on the queue
        }
      }
    } catch (err) {
      console.error("Receive error:", err);
      // optional backoff on failures
      await new Promise((r) => setTimeout(r, 2000));
    }
  }
}

// start polling
pollAndProcess().catch((e) => {
  console.error(e);
  process.exit(1);
});





