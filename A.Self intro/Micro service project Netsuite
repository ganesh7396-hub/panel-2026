const productsList = [
  "iPhone",
  "Samsung",
  "OnePlus",
  "Realme",
  "Oppo",
  "Vivo",
  "Nokia"
];




const ProductSearch =()=>{
    const [search,setSearch]=useState("");
    const [count,setCount]=useState(0);


      // 🔥 Expensive operation (simulated)
  const filteredProducts = useMemo(() => {
    console.log("Filtering running...");
    
    return productsList.filter((item) =>
      item.toLowerCase().includes(search.toLowerCase())
    );
  }, [search]); // only runs when search changes

    return(
        <>
        
        <h2> Product Search</h2>


        <input type="text"
        placeholder="search product..."
        value={search}
        onChange={(e)=>{setSearch(e.target.value)}}/>
        <h3> Result :</h3>

  {filteredProducts.map((item, index) => {
  return <p key={index}>{item}</p>;
})}
        <button onClick={()=>{setCount(count+1)}}>
Count:{count}

        </button>


        </>
    )

}

export default ProductSearch;





React Class Component Lifecycle:-
-------------------------------
Lifecycle = how a component is created, updated, and removed
componentDidMount():-Runs when component first loads
componentDidUpdate():-Runs when state or props change
componentWillUnmount():-Runs when component is removed


React Functional Component Lifecycle:-
-----------------------------------
3 Main Phases
Runs only once
1)Mounting (Component Created)
useEffect(() => {
  console.log("Component Mounted");
}, []);

2.Updating (State/Props Change)

Runs when dependency changes
useEffect(() => {
  console.log("Updated");
}, [count]);

3.Unmounting (Component Removed)
Cleanup function
useEffect(() => {
  return () => {
    console.log("Component Unmounted");
  };
}, []);



